{
  "name": "hikari-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "PATH=\"/opt/homebrew/opt/node@24/bin:$PATH\" tsx watch src/index.ts",
    "build": "PATH=\"/opt/homebrew/opt/node@24/bin:$PATH\" tsc -p tsconfig.json",
    "start": "PATH=\"/opt/homebrew/opt/node@24/bin:$PATH\" node dist/index.js",
    "test": "PATH=\"/opt/homebrew/opt/node@24/bin:$PATH\" vitest run",
    "test:watch": "PATH=\"/opt/homebrew/opt/node@24/bin:$PATH\" vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^12.9.0",
    "execa": "^9.5.0",
    "fast-xml-parser": "^4.5.0",
    "fastify": "^5.1.0",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
