# Which scorer to use: "lmstudio" | "ollama" | "claude"
LLM_PROVIDER=lmstudio

# LM Studio endpoint (OpenAI-compatible, default port 1234)
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_MODEL=qwen3-27b

# Ollama endpoint (only used if LLM_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Anthropic API key + model (only used if LLM_PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5

# Data directory (created if missing)
HIKARI_DATA_DIR=~/.hikari

# HTTP port
PORT=3000

# Daily budget (hard limit, per spec decision #8)
DAILY_BUDGET=15

# Disk limit for video cache in GB (per spec decision #9)
DISK_LIMIT_GB=10
