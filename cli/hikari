#!/usr/bin/env bash
# Hikari Server CLI — start/stop/inspect the local backend daemon.
# Default action (no args) = start in background.

set -e

# ─── Config ─────────────────────────────────────────────────────────────────
BACKEND_DIR="/Users/ayysir/Desktop/Hikari/backend"
NODE_PATH_PREFIX="/opt/homebrew/opt/node@24/bin"

PORT="${PORT:-3939}"
SERVICE_NAME="hikari"
# Magic-DNS hostname is stable across IP changes. Override via $HIKARI_HOST if needed.
MAGIC_DNS_HOST="${HIKARI_HOST:-macbook-pro.taile64a95.ts.net}"

STATE_DIR="$HOME/.hikari"
PID_FILE="$STATE_DIR/server.pid"
LOG_FILE="$STATE_DIR/server.log"

mkdir -p "$STATE_DIR"

# ─── Helpers ────────────────────────────────────────────────────────────────
RED=$'\033[31m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'; AMBER=$'\033[38;5;214m'
DIM=$'\033[2m'; BOLD=$'\033[1m'; RESET=$'\033[0m'

read_pid() {
    [[ -f "$PID_FILE" ]] && cat "$PID_FILE" || echo ""
}

# Process alive AND health endpoint identifies as Hikari.
is_running() {
    local pid
    pid=$(read_pid)
    [[ -n "$pid" ]] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    health_says_hikari
}

# Returns 0 only if /health body contains "service":"hikari".
# Prevents foreign servers (Remotion, Vite, …) from masquerading as Hikari.
health_says_hikari() {
    local body
    body=$(curl -s --max-time 1 "http://localhost:$PORT/health" 2>/dev/null) || return 1
    [[ -n "$body" ]] || return 1
    echo "$body" | grep -q "\"service\":[[:space:]]*\"$SERVICE_NAME\""
}

kill_tree() {
    local pid="$1"
    local sig="${2:-TERM}"
    pkill -"$sig" -P "$pid" 2>/dev/null || true
    kill -"$sig" "$pid" 2>/dev/null || true
}

# Returns the PID that holds $PORT, or empty if none.
port_holder_pid() {
    lsof -nP -iTCP:"$PORT" -sTCP:LISTEN -t 2>/dev/null | head -n1
}

# Waits up to 5s for the server to come up AND identify itself as Hikari.
wait_for_health() {
    local i=0
    while (( i < 20 )); do
        if health_says_hikari; then
            return 0
        fi
        sleep 0.25
        ((i++))
    done
    return 1
}

# ─── Commands ───────────────────────────────────────────────────────────────
cmd_start() {
    if is_running; then
        echo "${YELLOW}Hikari läuft schon${RESET} (PID $(read_pid))"
        echo "${DIM}  → ${BOLD}hikari status${RESET}${DIM} oder ${BOLD}hikari logs${RESET}${DIM} für Details${RESET}"
        return 0
    fi

    # Stale PID-File aufräumen (Prozess ist tot oder identifiziert sich nicht als hikari).
    if [[ -f "$PID_FILE" ]]; then
        local stale_pid
        stale_pid=$(read_pid)
        if [[ -n "$stale_pid" ]] && kill -0 "$stale_pid" 2>/dev/null; then
            # Prozess lebt, aber Health-Check schlug fehl → unser eigener kaputter Prozess
            echo "${DIM}Räume hängenden Prozess auf (PID $stale_pid)…${RESET}"
            kill_tree "$stale_pid" TERM
            sleep 0.5
            kill -0 "$stale_pid" 2>/dev/null && kill_tree "$stale_pid" KILL
        fi
        rm -f "$PID_FILE"
    fi

    # Pre-Flight: hält jemand Fremdes den Port?
    local holder
    holder=$(port_holder_pid)
    if [[ -n "$holder" ]]; then
        local cmd
        cmd=$(ps -p "$holder" -o command= 2>/dev/null | cut -c1-90)
        echo "${RED}Port $PORT ist belegt — von einem fremden Prozess:${RESET}"
        echo "${DIM}  PID $holder: $cmd${RESET}"
        echo ""
        echo "${DIM}Optionen:${RESET}"
        echo "${DIM}  • ${BOLD}kill $holder${RESET}${DIM} — wenn du den Prozess nicht mehr brauchst${RESET}"
        echo "${DIM}  • ${BOLD}PORT=3940 hikari${RESET}${DIM} — Hikari auf einem anderen Port starten${RESET}"
        echo "${DIM}    (App-URL muss dann in Settings angepasst werden)${RESET}"
        return 1
    fi

    echo "${AMBER}Starte Hikari im Hintergrund auf Port $PORT…${RESET}"
    cd "$BACKEND_DIR"
    : > "$LOG_FILE"
    if ! PATH="$NODE_PATH_PREFIX:$PATH" npm run build >> "$LOG_FILE" 2>&1; then
        echo "${RED}Build fehlgeschlagen.${RESET}"
        echo "${DIM}  Letzte Log-Zeilen:${RESET}"
        tail -n 12 "$LOG_FILE" | sed "s/^/  /"
        echo "${DIM}  Volle Logs: ${BOLD}hikari logs${RESET}"
        return 1
    fi
    PORT="$PORT" PATH="$NODE_PATH_PREFIX:$PATH" nohup node dist/index.js >> "$LOG_FILE" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"

    if ! kill -0 "$pid" 2>/dev/null; then
        echo "${RED}Prozess ist sofort gestorben.${RESET}"
        rm -f "$PID_FILE"
        echo "${DIM}  Letzte Log-Zeilen:${RESET}"
        tail -n 12 "$LOG_FILE" | sed "s/^/  /"
        return 1
    fi

    if wait_for_health; then
        echo "${GREEN}Läuft${RESET} (PID $pid)"
        echo "${DIM}  Logs:    ${BOLD}hikari logs${RESET}"
        echo "${DIM}  Stoppen: ${BOLD}hikari stop${RESET}"
        echo "${DIM}  URL:     http://localhost:$PORT  ·  http://$MAGIC_DNS_HOST:$PORT${RESET}"
    else
        echo "${RED}Server reagiert nicht oder identifiziert sich nicht als Hikari binnen 5s.${RESET}"
        if ! kill -0 "$pid" 2>/dev/null; then
            echo "${DIM}  Prozess ist gestorben.${RESET}"
            rm -f "$PID_FILE"
        fi
        echo "${DIM}  Letzte Log-Zeilen:${RESET}"
        tail -n 12 "$LOG_FILE" | sed "s/^/  /"
        echo "${DIM}  Volle Logs: ${BOLD}hikari logs${RESET}"
        return 1
    fi
}

cmd_stop() {
    local pid
    pid=$(read_pid)

    if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
        if [[ -f "$PID_FILE" ]]; then
            rm -f "$PID_FILE"
            echo "${DIM}Stale PID-Datei aufgeräumt.${RESET}"
        else
            echo "${DIM}Lief nicht.${RESET}"
        fi
        return 0
    fi

    echo "${AMBER}Stoppe (PID $pid)…${RESET}"
    kill_tree "$pid" TERM

    local i=0
    while (( i < 20 )) && kill -0 "$pid" 2>/dev/null; do
        sleep 0.25
        ((i++))
    done

    if kill -0 "$pid" 2>/dev/null; then
        echo "${YELLOW}TERM ignoriert — nehme den Hammer.${RESET}"
        kill_tree "$pid" KILL
    fi

    rm -f "$PID_FILE"
    echo "${GREEN}Gestoppt.${RESET}"
}

cmd_status() {
    if is_running; then
        local pid
        pid=$(read_pid)
        echo "${GREEN}● running${RESET}  (PID $pid, Port $PORT)"
        local body
        body=$(curl -s --max-time 1 "http://localhost:$PORT/health" 2>/dev/null)
        echo "${DIM}  /health: $body${RESET}"
        if [[ -d "$STATE_DIR" ]]; then
            local size
            size=$(du -sh "$STATE_DIR" 2>/dev/null | awk '{print $1}')
            echo "${DIM}  $STATE_DIR: $size${RESET}"
        fi
        return 0
    fi

    # Nicht "running" laut PID — aber liegt da was anderes auf dem Port?
    local holder
    holder=$(port_holder_pid)
    if [[ -n "$holder" ]]; then
        local cmd
        cmd=$(ps -p "$holder" -o command= 2>/dev/null | cut -c1-90)
        echo "${YELLOW}○ stopped${RESET}  ${DIM}(aber Port $PORT ist belegt)${RESET}"
        echo "${DIM}  PID $holder: $cmd${RESET}"
    else
        echo "${DIM}○ stopped${RESET}"
    fi
    [[ -f "$LOG_FILE" ]] && echo "${DIM}  Letzte Logs: ${BOLD}hikari logs${RESET}"
}

cmd_restart() {
    cmd_stop
    sleep 0.5
    cmd_start
}

cmd_logs() {
    if [[ ! -f "$LOG_FILE" ]]; then
        echo "${DIM}Noch keine Logs (Server lief noch nicht).${RESET}"
        return 1
    fi
    tail -F -n 50 "$LOG_FILE"
}

cmd_fg() {
    if is_running; then
        echo "${YELLOW}Background-Server läuft schon (PID $(read_pid)).${RESET}"
        echo "${DIM}  Erst ${BOLD}hikari stop${RESET}${DIM} damit nichts kollidiert.${RESET}"
        return 1
    fi
    local holder
    holder=$(port_holder_pid)
    if [[ -n "$holder" ]]; then
        echo "${RED}Port $PORT ist belegt (PID $holder). Erst aufräumen.${RESET}"
        return 1
    fi
    echo "${AMBER}Starte im Vordergrund auf Port $PORT — Ctrl+C beendet.${RESET}"
    cd "$BACKEND_DIR"
    exec env PORT="$PORT" PATH="$NODE_PATH_PREFIX:$PATH" npm run dev
}

cmd_help() {
    cat <<EOF
${BOLD}Hikari${RESET} — Backend-Server CLI

${BOLD}USAGE${RESET}
  ${AMBER}hikari${RESET}              Starte Server im Hintergrund (default)
  ${AMBER}hikari start${RESET}        Wie oben
  ${AMBER}hikari stop${RESET}         Stoppe Server
  ${AMBER}hikari restart${RESET}      Stop + Start
  ${AMBER}hikari status${RESET}       Läuft er? + Health-Check
  ${AMBER}hikari logs${RESET}         Live-Logs verfolgen (tail -F)
  ${AMBER}hikari fg${RESET}           Im Vordergrund starten (Ctrl+C beendet)
  ${AMBER}hikari -h${RESET}           Diese Hilfe

${BOLD}ENV VARS${RESET}
  ${DIM}PORT=3940 hikari        Anderer Port (Default: 3939)${RESET}
  ${DIM}HIKARI_HOST=…  hikari   Anderer Tailscale-Hostname für die URL-Anzeige${RESET}

${BOLD}DATEIEN${RESET}
  ${DIM}~/.hikari/server.pid    PID des laufenden Servers${RESET}
  ${DIM}~/.hikari/server.log    Server-Output (alle Logs)${RESET}

${BOLD}URLS${RESET}
  ${DIM}http://localhost:$PORT          (lokal)${RESET}
  ${DIM}http://$MAGIC_DNS_HOST:$PORT  (Tailscale, fürs Handy)${RESET}
EOF
}

# ─── Dispatch ───────────────────────────────────────────────────────────────
case "${1:-start}" in
    start|up)         cmd_start ;;
    stop|down)        cmd_stop ;;
    restart)          cmd_restart ;;
    status|st)        cmd_status ;;
    logs|log|tail)    cmd_logs ;;
    fg|foreground)    cmd_fg ;;
    -h|--help|help)   cmd_help ;;
    *)
        echo "${RED}Unknown command: $1${RESET}" >&2
        echo ""
        cmd_help
        exit 1
        ;;
esac
