#!/usr/bin/env bash
# Hikari Server CLI — start/stop/inspect the local backend daemon + clipper worker.
# Default action (no args) = start BOTH in background.

set -e

# ─── Config ─────────────────────────────────────────────────────────────────
BACKEND_DIR="/Users/ayysir/Desktop/Hikari/backend"
NODE_PATH_PREFIX="/opt/homebrew/opt/node@24/bin"

PORT="${PORT:-3939}"
SERVICE_NAME="hikari"
# Magic-DNS hostname is stable across IP changes. Override via $HIKARI_HOST if needed.
MAGIC_DNS_HOST="${HIKARI_HOST:-macbook-pro.taile64a95.ts.net}"

STATE_DIR="$HOME/.hikari"
PID_FILE="$STATE_DIR/server.pid"
LOG_FILE="$STATE_DIR/server.log"
CLIPPER_PID_FILE="$STATE_DIR/clipper.pid"
CLIPPER_LOG_FILE="$STATE_DIR/clipper.log"

mkdir -p "$STATE_DIR"

# ─── Helpers ────────────────────────────────────────────────────────────────
RED=$'\033[31m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'; AMBER=$'\033[38;5;214m'
DIM=$'\033[2m'; BOLD=$'\033[1m'; RESET=$'\033[0m'

read_pid() {
    [[ -f "$PID_FILE" ]] && cat "$PID_FILE" || echo ""
}

read_clipper_pid() {
    [[ -f "$CLIPPER_PID_FILE" ]] && cat "$CLIPPER_PID_FILE" || echo ""
}

# Process alive AND health endpoint identifies as Hikari.
is_running() {
    local pid
    pid=$(read_pid)
    [[ -n "$pid" ]] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    health_says_hikari
}

# Returns 0 only if /health body contains "service":"hikari".
# Prevents foreign servers (Remotion, Vite, …) from masquerading as Hikari.
health_says_hikari() {
    local body
    body=$(curl -s --max-time 1 "http://localhost:$PORT/health" 2>/dev/null) || return 1
    [[ -n "$body" ]] || return 1
    echo "$body" | grep -q "\"service\":[[:space:]]*\"$SERVICE_NAME\""
}

# Clipper is running if PID file exists, process is alive, and its command mentions clipper-worker.
is_clipper_running() {
    local pid
    pid=$(read_clipper_pid)
    [[ -n "$pid" ]] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    local cmd
    cmd=$(ps -p "$pid" -o command= 2>/dev/null) || return 1
    echo "$cmd" | grep -q "clipper-worker"
}

kill_tree() {
    local pid="$1"
    local sig="${2:-TERM}"
    pkill -"$sig" -P "$pid" 2>/dev/null || true
    kill -"$sig" "$pid" 2>/dev/null || true
}

# Returns the PID that holds $PORT, or empty if none.
port_holder_pid() {
    lsof -nP -iTCP:"$PORT" -sTCP:LISTEN -t 2>/dev/null | head -n1
}

# Waits up to 5s for the server to come up AND identify itself as Hikari.
wait_for_health() {
    local i=0
    while (( i < 20 )); do
        if health_says_hikari; then
            return 0
        fi
        sleep 0.25
        ((i++))
    done
    return 1
}

# Waits up to 3s for the clipper process to be alive.
wait_for_clipper() {
    local pid="$1"
    local i=0
    while (( i < 12 )); do
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        sleep 0.25
        ((i++))
    done
    return 1
}

# LM Studio reachability check (silent, returns 0 if reachable).
lm_studio_reachable() {
    local status
    status=$(curl -s --max-time 1 -o /dev/null -w "%{http_code}" "http://localhost:1234/v1/models" 2>/dev/null)
    [[ "$status" == "200" ]]
}

# ─── Backend start/stop ──────────────────────────────────────────────────────
start_backend() {
    if is_running; then
        echo "${YELLOW}Backend läuft schon${RESET} (PID $(read_pid))"
        return 0
    fi

    # Stale PID-File aufräumen.
    if [[ -f "$PID_FILE" ]]; then
        local stale_pid
        stale_pid=$(read_pid)
        if [[ -n "$stale_pid" ]] && kill -0 "$stale_pid" 2>/dev/null; then
            echo "${DIM}Räume hängenden Backend-Prozess auf (PID $stale_pid)…${RESET}"
            kill_tree "$stale_pid" TERM
            sleep 0.5
            kill -0 "$stale_pid" 2>/dev/null && kill_tree "$stale_pid" KILL
        fi
        rm -f "$PID_FILE"
    fi

    # Pre-Flight: hält jemand Fremdes den Port?
    local holder
    holder=$(port_holder_pid)
    if [[ -n "$holder" ]]; then
        local cmd
        cmd=$(ps -p "$holder" -o command= 2>/dev/null | cut -c1-90)
        echo "${RED}Port $PORT ist belegt — von einem fremden Prozess:${RESET}"
        echo "${DIM}  PID $holder: $cmd${RESET}"
        echo ""
        echo "${DIM}Optionen:${RESET}"
        echo "${DIM}  • ${BOLD}kill $holder${RESET}${DIM} — wenn du den Prozess nicht mehr brauchst${RESET}"
        echo "${DIM}  • ${BOLD}PORT=3940 hikari${RESET}${DIM} — Hikari auf einem anderen Port starten${RESET}"
        return 1
    fi

    echo "${AMBER}Starte Backend im Hintergrund auf Port $PORT…${RESET}"
    cd "$BACKEND_DIR"
    : > "$LOG_FILE"
    # Build: tsc emits JS even when there are type errors (noEmitOnError defaults to false).
    # The npm script uses && so schema.sql copy is skipped on tsc type errors — we do it
    # manually here to ensure the DB migration file is always present.
    PATH="$NODE_PATH_PREFIX:$PATH" npx tsc -p tsconfig.json >> "$LOG_FILE" 2>&1 || true
    mkdir -p dist/db && cp src/db/schema.sql dist/db/schema.sql >> "$LOG_FILE" 2>&1 || true
    if [[ ! -f "dist/index.js" ]]; then
        echo "${RED}Build schlug fehl — dist/index.js nicht vorhanden.${RESET}"
        echo "${DIM}  Letzte Log-Zeilen:${RESET}"
        tail -n 12 "$LOG_FILE" | sed "s/^/  /"
        echo "${DIM}  Volle Logs: ${BOLD}hikari logs backend${RESET}"
        return 1
    fi
    PORT="$PORT" PATH="$NODE_PATH_PREFIX:$PATH" nohup node dist/index.js >> "$LOG_FILE" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"

    if ! kill -0 "$pid" 2>/dev/null; then
        echo "${RED}Backend-Prozess ist sofort gestorben.${RESET}"
        rm -f "$PID_FILE"
        tail -n 12 "$LOG_FILE" | sed "s/^/  /"
        return 1
    fi

    if wait_for_health; then
        echo "${GREEN}Backend läuft${RESET} (PID $pid, Port $PORT)"
    else
        echo "${RED}Backend reagiert nicht binnen 5s.${RESET}"
        if ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$PID_FILE"
        fi
        tail -n 12 "$LOG_FILE" | sed "s/^/  /"
        return 1
    fi
}

stop_backend() {
    local pid
    pid=$(read_pid)

    if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
        if [[ -f "$PID_FILE" ]]; then
            rm -f "$PID_FILE"
            echo "${DIM}Backend stale PID aufgeräumt.${RESET}"
        else
            echo "${DIM}Backend lief nicht.${RESET}"
        fi
        return 0
    fi

    echo "${AMBER}Stoppe Backend (PID $pid)…${RESET}"
    kill_tree "$pid" TERM

    local i=0
    while (( i < 20 )) && kill -0 "$pid" 2>/dev/null; do
        sleep 0.25
        ((i++))
    done

    if kill -0 "$pid" 2>/dev/null; then
        echo "${YELLOW}TERM ignoriert — nehme den Hammer.${RESET}"
        kill_tree "$pid" KILL
    fi

    rm -f "$PID_FILE"
    echo "${GREEN}Backend gestoppt.${RESET}"
}

# ─── Clipper start/stop ──────────────────────────────────────────────────────
start_clipper() {
    if is_clipper_running; then
        echo "${YELLOW}Clipper-Worker läuft schon${RESET} (PID $(read_clipper_pid))"
        return 0
    fi

    # Stale PID-File aufräumen.
    if [[ -f "$CLIPPER_PID_FILE" ]]; then
        local stale_pid
        stale_pid=$(read_clipper_pid)
        if [[ -n "$stale_pid" ]] && kill -0 "$stale_pid" 2>/dev/null; then
            echo "${DIM}Räume hängenden Clipper-Prozess auf (PID $stale_pid)…${RESET}"
            kill_tree "$stale_pid" TERM
            sleep 0.5
            kill -0 "$stale_pid" 2>/dev/null && kill_tree "$stale_pid" KILL
        fi
        rm -f "$CLIPPER_PID_FILE"
    fi

    echo "${AMBER}Starte Clipper-Worker im Hintergrund…${RESET}"
    cd "$BACKEND_DIR"
    : > "$CLIPPER_LOG_FILE"
    PATH="$NODE_PATH_PREFIX:$PATH" nohup npm run clipper >> "$CLIPPER_LOG_FILE" 2>&1 &
    local pid=$!
    echo "$pid" > "$CLIPPER_PID_FILE"

    if wait_for_clipper "$pid"; then
        echo "${GREEN}Clipper-Worker läuft${RESET} (PID $pid)"
    else
        echo "${RED}Clipper-Worker ist sofort gestorben.${RESET}"
        rm -f "$CLIPPER_PID_FILE"
        tail -n 8 "$CLIPPER_LOG_FILE" | sed "s/^/  /"
        return 1
    fi
}

stop_clipper() {
    local pid
    pid=$(read_clipper_pid)

    if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
        if [[ -f "$CLIPPER_PID_FILE" ]]; then
            rm -f "$CLIPPER_PID_FILE"
            echo "${DIM}Clipper stale PID aufgeräumt.${RESET}"
        else
            echo "${DIM}Clipper lief nicht.${RESET}"
        fi
        return 0
    fi

    echo "${AMBER}Stoppe Clipper-Worker (PID $pid)…${RESET}"
    kill_tree "$pid" TERM

    local i=0
    while (( i < 20 )) && kill -0 "$pid" 2>/dev/null; do
        sleep 0.25
        ((i++))
    done

    if kill -0 "$pid" 2>/dev/null; then
        echo "${YELLOW}TERM ignoriert — nehme den Hammer.${RESET}"
        kill_tree "$pid" KILL
    fi

    rm -f "$CLIPPER_PID_FILE"
    echo "${GREEN}Clipper gestoppt.${RESET}"
}

# ─── Commands ───────────────────────────────────────────────────────────────
cmd_start() {
    start_backend || return 1
    start_clipper || true  # Clipper failure doesn't abort
    echo ""
    echo "${DIM}  Logs:      ${BOLD}hikari logs${RESET}${DIM} (beide) · ${BOLD}hikari logs backend${RESET} · ${BOLD}hikari logs clipper${RESET}"
    echo "${DIM}  Stoppen:   ${BOLD}hikari stop${RESET}"
    echo "${DIM}  URL:       http://localhost:$PORT  ·  http://$MAGIC_DNS_HOST:$PORT${RESET}"
}

cmd_stop() {
    stop_backend
    stop_clipper
}

cmd_status() {
    echo "${BOLD}Backend:${RESET}"
    if is_running; then
        local pid
        pid=$(read_pid)
        echo "  ${GREEN}● running${RESET}  (PID $pid, Port $PORT)"
        local body
        body=$(curl -s --max-time 1 "http://localhost:$PORT/health" 2>/dev/null)
        echo "  ${DIM}/health: $body${RESET}"
    else
        local holder
        holder=$(port_holder_pid)
        if [[ -n "$holder" ]]; then
            local cmd
            cmd=$(ps -p "$holder" -o command= 2>/dev/null | cut -c1-90)
            echo "  ${YELLOW}○ stopped${RESET}  ${DIM}(aber Port $PORT ist belegt)${RESET}"
            echo "  ${DIM}PID $holder: $cmd${RESET}"
        else
            echo "  ${DIM}○ stopped${RESET}"
        fi
    fi

    echo ""
    echo "${BOLD}Clipper-Worker:${RESET}"
    if is_clipper_running; then
        local cpid
        cpid=$(read_clipper_pid)
        echo "  ${GREEN}● running${RESET}  (PID $cpid)"
    else
        echo "  ${DIM}○ stopped${RESET}"
    fi

    echo ""
    echo "${BOLD}LM Studio:${RESET}"
    if lm_studio_reachable; then
        echo "  ${GREEN}✓ erreichbar${RESET}  (http://localhost:1234)"
    else
        echo "  ${YELLOW}✗ nicht erreichbar${RESET}  ${DIM}(Clipper kann nicht analysieren)${RESET}"
    fi

    if [[ -d "$STATE_DIR" ]]; then
        local size
        size=$(du -sh "$STATE_DIR" 2>/dev/null | awk '{print $1}')
        echo ""
        echo "${DIM}  $STATE_DIR: $size${RESET}"
    fi
}

cmd_restart() {
    stop_backend
    stop_clipper
    sleep 0.5
    start_backend || return 1
    start_clipper || true
    echo ""
    echo "${DIM}  URL: http://localhost:$PORT  ·  http://$MAGIC_DNS_HOST:$PORT${RESET}"
}

cmd_logs() {
    local target="${1:-both}"
    case "$target" in
        backend)
            if [[ ! -f "$LOG_FILE" ]]; then
                echo "${DIM}Noch keine Backend-Logs.${RESET}"
                return 1
            fi
            tail -F -n 50 "$LOG_FILE"
            ;;
        clipper)
            if [[ ! -f "$CLIPPER_LOG_FILE" ]]; then
                echo "${DIM}Noch keine Clipper-Logs.${RESET}"
                return 1
            fi
            tail -F -n 50 "$CLIPPER_LOG_FILE"
            ;;
        both|*)
            if [[ ! -f "$LOG_FILE" ]] && [[ ! -f "$CLIPPER_LOG_FILE" ]]; then
                echo "${DIM}Noch keine Logs (weder Backend noch Clipper liefen).${RESET}"
                return 1
            fi
            # tail -F both files interleaved; fall back gracefully if one doesn't exist yet
            local files=()
            [[ -f "$LOG_FILE" ]] && files+=("$LOG_FILE")
            [[ -f "$CLIPPER_LOG_FILE" ]] && files+=("$CLIPPER_LOG_FILE")
            tail -F -n 50 "${files[@]}"
            ;;
    esac
}

cmd_fg() {
    if is_running; then
        echo "${YELLOW}Background-Server läuft schon (PID $(read_pid)).${RESET}"
        echo "${DIM}  Erst ${BOLD}hikari stop${RESET}${DIM} damit nichts kollidiert.${RESET}"
        return 1
    fi
    local holder
    holder=$(port_holder_pid)
    if [[ -n "$holder" ]]; then
        echo "${RED}Port $PORT ist belegt (PID $holder). Erst aufräumen.${RESET}"
        return 1
    fi
    echo "${AMBER}Starte Backend im Vordergrund auf Port $PORT — Ctrl+C beendet.${RESET}"
    echo "${DIM}(Clipper-Worker nicht gestartet — nutze ${BOLD}hikari start${RESET}${DIM} für beide.)${RESET}"
    cd "$BACKEND_DIR"
    exec env PORT="$PORT" PATH="$NODE_PATH_PREFIX:$PATH" npm run dev
}

cmd_help() {
    cat <<EOF
${BOLD}Hikari${RESET} — Backend + Clipper-Worker CLI

${BOLD}USAGE${RESET}
  ${AMBER}hikari${RESET}                    Starte Backend + Clipper-Worker (default)
  ${AMBER}hikari start${RESET}              Wie oben
  ${AMBER}hikari stop${RESET}               Stoppe beide
  ${AMBER}hikari restart${RESET}            Stop + Start beider
  ${AMBER}hikari status${RESET}             Status beider + LM Studio Erreichbarkeit
  ${AMBER}hikari logs${RESET}               Live-Logs beider interleaved (tail -F)
  ${AMBER}hikari logs backend${RESET}       Nur Backend-Logs
  ${AMBER}hikari logs clipper${RESET}       Nur Clipper-Logs
  ${AMBER}hikari fg${RESET}                 Backend im Vordergrund starten (debug)
  ${AMBER}hikari -h${RESET}                 Diese Hilfe

${BOLD}ENV VARS${RESET}
  ${DIM}PORT=3940 hikari          Anderer Port (Default: 3939)${RESET}
  ${DIM}HIKARI_HOST=…  hikari     Anderer Tailscale-Hostname für die URL-Anzeige${RESET}

${BOLD}DATEIEN${RESET}
  ${DIM}~/.hikari/server.pid      PID des laufenden Backends${RESET}
  ${DIM}~/.hikari/server.log      Backend-Output${RESET}
  ${DIM}~/.hikari/clipper.pid     PID des laufenden Clipper-Workers${RESET}
  ${DIM}~/.hikari/clipper.log     Clipper-Worker-Output${RESET}

${BOLD}URLS${RESET}
  ${DIM}http://localhost:$PORT            (lokal)${RESET}
  ${DIM}http://$MAGIC_DNS_HOST:$PORT    (Tailscale, fürs Handy)${RESET}
EOF
}

# ─── Dispatch ───────────────────────────────────────────────────────────────
case "${1:-start}" in
    start|up)         cmd_start ;;
    stop|down)        cmd_stop ;;
    restart)          cmd_restart ;;
    status|st)        cmd_status ;;
    logs|log|tail)    cmd_logs "${2:-both}" ;;
    fg|foreground)    cmd_fg ;;
    -h|--help|help)   cmd_help ;;
    *)
        echo "${RED}Unknown command: $1${RESET}" >&2
        echo ""
        cmd_help
        exit 1
        ;;
esac
